!complex(dpc), dimension(0:1, 0:3, -Nmax:Nmax) :: W2

W2(0,0,l) =
(I*Sqrt[Pi/2]*Vt*(2 + 2*Wm*z[-4] + z[-2]))/dom

W2(0,1,l) =
(I*Sqrt[Pi]*Vt^2*(2*Wm*z[-3] + z[-1]))/dom

W2(0,2,l) =
(I*Sqrt[2*Pi]*Vt^3*(1 + 2*Wm*z[-2]))/dom

W2(0,3,l) =
((4*I)*Sqrt[Pi]*Vt^4*Wm*z[-1])/dom

W2(1,0,l) =
(I*Sqrt[Pi]*Vt^2*(2*Wm*z[-3] + z[-1]))/dom

W2(1,1,l) =
(I*Sqrt[2*Pi]*Vt^3*(1 + 2*Wm*z[-2]))/dom

W2(1,2,l) =
((4*I)*Sqrt[Pi]*Vt^4*Wm*z[-1])/dom

W2(1,3,l) =
((4*I)*Sqrt[2*Pi]*Vt^5*Wm)/dom
