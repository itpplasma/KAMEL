                        FormBox[\(-\[Infinity]\),
                          "TraditionalForm"], 
                        StyleBox[",",
                          "MR"], " ", 
                        FormBox["\[Infinity]",
                          "TraditionalForm"]}], 
                      StyleBox["}",
                        "MR"]}], " ", 
                    StyleBox[",",
                      "MR"], " ", \({tau, \ 0, \ Infinity}\)}], 
                  StyleBox["]",
                    "MR"]}]}], 
              StyleBox[",",
                "MR"], 
              RowBox[{
                StyleBox["{",
                  "MR"], 
                RowBox[{
                  StyleBox["w1",
                    "MR"], 
                  StyleBox[",",
                    "MR"], " ", \(-\[Infinity]\), 
                  StyleBox[",",
                    "MR"], " ", "\[Infinity]"}], 
                StyleBox["}",
                  "MR"]}]}], "]"}]}], " ", ";"}]}]], "Input"],

Cell[BoxData[
    RowBox[{\( (*Check\ of\ integrals\ over\ velocities\ \(\(w\)\(:\)\)*) \), 
      "\[IndentingNewLine]", 
      RowBox[{\(SuL = {m \[Rule] 0, \ n \[Rule] 0, \ nu -> 10^4, \ 
              Vt \[Rule] 10^8, kp \[Rule] 0.1, \ omega -> 10^3, \ 
              omega0 -> 10^4};\), "\[IndentingNewLine]", 
        "\[IndentingNewLine]", \(Aw = J1ana[0, 0, \ nu];\), 
        "\[IndentingNewLine]", 
        RowBox[{
          StyleBox["Aw",
            "MR"], 
          StyleBox["=",
            "MR"], 
          RowBox[{
            StyleBox["N",
              "MR"], 
            StyleBox["[",
              "MR"], \(ReplaceAll[Aw, SuL], 20\), "]"}]}], 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{
          RowBox[{"Tw", "=", 
            RowBox[{"NIntegrate", "[", 
              RowBox[{
                RowBox[{"ReplaceAll", "[", 
