              "\[IndentingNewLine]", 
              
              RowBox[{\(res = J1derNC[m, \ n, nu]\), ";", 
                "\[IndentingNewLine]", \( (*\(Print[res];\)*) \), 
                "\[IndentingNewLine]", 
                "\[IndentingNewLine]", \(res = 
                  FullSimplify[ReplaceRepeated[res, {ErfiRule}]]\), ";", 
                "\[IndentingNewLine]", \(res = 
                  Simplify[Assuming[kp > 0, Simplify[res]]]\), ";", 
                "\[IndentingNewLine]", \(res = 
                  Simplify[
                    ReplaceRepeated[
                      res, {omega - omega0 \[Rule] z\ Sqrt[2] kp\ Vt, \ 
                        kp \[Rule] \(\(dom/z\)/Sqrt[2]\)/Vt}]]\), ";", 
                "\[IndentingNewLine]", \(res = 
                  FullSimplify[
                    ReplaceRepeated[
                      res, {W[z] \[Rule] 
