Notebook[{

Cell[CellGroupData[{
Cell[BoxData[
    \(\(\( (*Green\ \(\(function\)\(:\)\)*) \)\(\[IndentingNewLine]\)\(\
\[IndentingNewLine]\)\(\(Ass1\  = \ {Element[{omega0, \ kp, \ nu, Vt, tau}, \ 
            Reals], \ Vt > 0, nu > 0, tau >= 0};\)\[IndentingNewLine]
    $Assumptions = Ass1\[IndentingNewLine]\[IndentingNewLine]
    \(a[tau_, nu_] := 
        Vt^2/2 \((1 - Exp[\(-2\) nu\ tau])\);\)\n\[IndentingNewLine]
    \(b[tau_, nu_] := 
        2  kp\ Vt^2/
            nu \((1 - 
              Exp[\(-nu\)\ tau])\);\)\[IndentingNewLine]\[IndentingNewLine]
    \(c[tau_, nu_] := \((I \((omega0 - omega)\) + kp^2  Vt^2/nu)\) 
          tau;\)\[IndentingNewLine]\n
    \(argG[w1_, \ w2_, tau_, \ nu_] := \ 
        I\ kp/nu\ \((w1 - w2)\) - 
          c[tau, \ nu] - \(1/4\)/
              a[tau, \ nu] \((w1 - w2\ Exp[\(-nu\)\ tau] + 
                  I\ b[tau, \ nu])\)^2;\)\[IndentingNewLine]\n
    \(G[w1_, \ w2_, tau_, \ nu_] := \ 
        1/Sqrt[4\ Pi\ a[tau, \ nu]] 
          Exp[argG[w1, \ w2, tau, \ nu]];\)\)\)\)], "Input"],

Cell[BoxData[
    \({\((omega0 | kp | nu | Vt | tau)\) \[Element] Reals, Vt > 0, nu > 0, 
      tau \[GreaterEqual] 0}\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(\(\( (*Check\ the\ solution\ of\ \(\(KE\)\(:\)\)*) \)\(\
\[IndentingNewLine]\)\(\(dt = 
        D[G[w1, \ w2, tau, \ nu], {tau, 1}];\)\[IndentingNewLine]
    \(d1 = D[G[w1, \ w2, tau, \ nu], {w1, 1}];\)\[IndentingNewLine]
    \(d2 = D[G[w1, \ w2, tau, \ nu], {w1, 2}];\)\[IndentingNewLine]
    Simplify[
        Expand[dt + \((I\ omega0\  + I\ kp\ w1\  - nu)\) 
              G[w1, \ w2, tau, \ nu] - nu\ Vt^2\ d2\  - \ nu\ w1\ \ d1]] /. 
      omega \[Rule] 0\)\)\)], "Input"],

Cell[BoxData[
    \(0\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[{
    RowBox[{"Simplify", "[", 
      RowBox[{
        StyleBox["Series",
          "MR"], 
        StyleBox["[",
          "MR"], 
        RowBox[{\(arg[w1, \ w2, tau, \ nu]\), 
          StyleBox[",",
            "MR"], " ", 
          RowBox[{
            StyleBox["{",
              "MR"], 
            RowBox[{
              StyleBox["nu",
                "MR"], 
              StyleBox[",",
                "MR"], " ", "0", 
              StyleBox[",",
                "MR"], " ", "1"}], 
            StyleBox["}",
              "MR"]}]}], 
        StyleBox["]",
          "MR"]}], 
      StyleBox["]",
        "MR"]}], "\n", \(Integrate[
      Exp[I \((omega - omega0 - kp\ w)\)\ tau], {tau, 0, \ 
        Infinity}]\), "\[IndentingNewLine]", "Null"}], "Input"],

Cell[BoxData[
    InterpretationBox[
      RowBox[{\(-\(\((w1 - w2)\)\^2\/\(4\ \((tau\ Vt\^2)\)\ nu\)\)\), 
        "+", \(\(4\ \[ImaginaryI]\ omega\ tau\ Vt\^2 - 
              4\ \[ImaginaryI]\ omega0\ tau\ Vt\^2 + \((\(-2\)\ \[ImaginaryI]\
\ kp\ tau\ Vt\^2 - w1 + w2)\)\ \((w1 + w2)\)\)\/\(4\ Vt\^2\)\), 
        "-", \(\(\((tau\ \((kp\^2\ tau\^2\ Vt\^4 + w1\^2 + w1\ w2 + 
                      w2\^2)\))\)\ nu\)\/\(12\ Vt\^2\)\), "+", 
        InterpretationBox[\(O[nu]\^2\),
          SeriesData[ nu, 0, {}, -1, 2, 1],
          Editable->False]}],
      SeriesData[ nu, 0, {
        Times[ 
          Rational[ -1, 4], 
          Power[ tau, -1], 
          Power[ Vt, -2], 
          Power[ 
            Plus[ w1, 
              Times[ -1, w2]], 2]], 
        Times[ 
          Rational[ 1, 4], 
          Power[ Vt, -2], 
          Plus[ 
            Times[ 
              Complex[ 0, 4], omega, tau, 
              Power[ Vt, 2]], 
            Times[ 
              Complex[ 0, -4], omega0, tau, 
              Power[ Vt, 2]], 
            Times[ 
              Plus[ 
                Times[ 
                  Complex[ 0, -2], kp, tau, 
                  Power[ Vt, 2]], 
                Times[ -1, w1], w2], 
              Plus[ w1, w2]]]], 
        Times[ 
          Rational[ -1, 12], tau, 
          Power[ Vt, -2], 
          Plus[ 
            Times[ 
              Power[ kp, 2], 
              Power[ tau, 2], 
              Power[ Vt, 4]], 
            Power[ w1, 2], 
            Times[ w1, w2], 
            Power[ w2, 2]]]}, -1, 2, 1],
      Editable->False]], "Output"],

Cell[BoxData[
    \(If[kp\ Im[w] < 
        Im[omega], \(-\(\[ImaginaryI]\/\(\(-omega\) + omega0 + kp\ w\)\)\), 
      Integrate[\[ExponentialE]\^\(\(-\[ImaginaryI]\)\ tau\ \((\(-omega\) + \
omega0 + kp\ w)\)\), {tau, 0, \[Infinity]}, 
        Assumptions \[Rule] 
          kp\ Im[w] \[GreaterEqual] Im[omega] && \((omega0 | kp)\) \[Element] 
              Reals]]\)], "Output"]
}, Open  ]],

Cell[BoxData[
    \(\(W1[n_] := 
        If[Mod[n, 2] \[Equal] 0, 
          Sqrt[2\ \[Pi]] \(\((n - 1)\)!!\) Vt^\((n + 1)\), 0];\)\)], "Input"],

