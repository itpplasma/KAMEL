Cell[CellGroupData[{

Cell[BoxData[
    \(\(\( (*a\ \(\(matrices\)\(:\)\)*) \)\(\[IndentingNewLine]\)\( (*zero\ \
order\ orbits*) \)\(\[IndentingNewLine]\)\( (*rl = 
        Sqrt[2 \( J/m\)/
              omc]*) \)\(\[IndentingNewLine]\)\(\[IndentingNewLine]\)\(\(rho \
= List[\(-\ rl\)\ Cos[phi2], \ 
          rl\ Sin[phi2]\ hz/r0, \ \(-rl\)\ Sin[phi2]\ ht/
              r0];\)\(\[IndentingNewLine]\)
    \(xg = List[r0, th2, z2];\)\(\n\)
    \(xc = xg + rho;\)\(\n\)
    \(theta = 
        List[phi2, th2, z2];\)\(\[IndentingNewLine]\)\(\[IndentingNewLine]\)
    \(dxcdth = D[xc, {theta}];\)\(\[IndentingNewLine]\)
    \(MatrixForm[
      dxcdth]\)\(\n\)\(\[IndentingNewLine]\)\( (*Exp\ factor*) \)\(\
\[IndentingNewLine]\)\( (*\(Fe = 
          Exp[I\ \((kt\ rho[\([2]\)] + 
                  kz\ rho[\([3]\)])\)];\)*) \)\(\[IndentingNewLine]\)
    \(Fe = 
        Exp[I\ ks\ rl\ Sin[
              phi2]];\)\(\[IndentingNewLine]\)\(\[IndentingNewLine]\)\( \
(*without\ Kroneker\ delta\ \(\(factor!!\)!\)*) \)\(\[IndentingNewLine]\)
    \(a[n_] := 
      rho[\([1]\)]^n\ /\(n!\) 
        Fe\ dxcdth\)\(\[IndentingNewLine]\)\(\[IndentingNewLine]\)
    \(Ass2 = {Element[{rl, ks, ht, hz, r0, \ m0, omc}, \ Reals], 
          rl \[GreaterEqual] 0, \ m0 > 0};\)\(\[IndentingNewLine]\)
    \($Assumptions = 
      Join[Ass1, \ Ass2]\)\(\[IndentingNewLine]\)\(\[IndentingNewLine]\)
    \(aF[n_, 
          l_] := \(Integrate[
              Exp[\(-I\)\ l\ phi2] a[n], {phi2, \ \(-Pi\), \ Pi}]/2\)/
          Pi;\)\(\[IndentingNewLine]\)\(\[IndentingNewLine]\)
    \(mod[p1_, \ p2_] := \ Sqrt[p1^2 + p2^2];\)\(\n\)
    \(arg[p1_, \ p2_] := \ ArcTan[p2/p1];\)\(\[IndentingNewLine]\)\(\n\)
    \(JE[l_, p1_, p2_] := 
      BesselJ[l, mod[p1, \ p2]\ rl]\ Exp[
          I\ l\ arg[p1, \ p2]]\)\(\[IndentingNewLine]\)\(\n\)
    \(Der1[l_, m_, p1_, p2_] := D[JE[l, p1, p2], \ {p2, m}];\)\(\n\)
    \(Der2[l_, m_, p1_, p2_] := 
        D[Der1[l, m, p1, p2], \ {p1, 1}];\)\(\n\)\(\[IndentingNewLine]\)
    \(Dmat[l_, m_, ks_] := 
        ReplaceAll[
          List[{\(-I\)\ Der2[l, m, p1, p2], 0, 
              0}, {\(-I\)\ hz/r0\ \ Der1[l, m + 1, p1, p2], \ 
              Der1[l, m, p1, p2], 0}, {I\ ht/r0\ \ Der1[l, m + 1, p1, p2], 
              0, \ Der1[l, m, p1, p2]}], {p1 \[Rule] ks, \ 
            p2 \[Rule] 0}];\)\(\[IndentingNewLine]\)\(\[IndentingNewLine]\)
    \(aFa[n_, l_] := 
        Refine[I^n/\(n!\)\ Dmat[l, n, ks], 
          ks \[GreaterEqual] 0];\)\(\[IndentingNewLine]\)
    \( (*\(aFa[n_, l_] := I^n/\(n!\)\ Dmat[l, n, ks];\)*) \)\)\)\)], "Input"],

Cell[BoxData[
    TagBox[
      RowBox[{"(", "\[NoBreak]", GridBox[{
            {\(rl\ Sin[phi2]\), "0", "0"},
            {\(\(hz\ rl\ Cos[phi2]\)\/r0\), "1", "0"},
            {\(-\(\(ht\ rl\ Cos[phi2]\)\/r0\)\), "0", "1"}
            },
          RowSpacings->1,
          ColumnSpacings->1,
          ColumnAlignments->{Left}], "\[NoBreak]", ")"}],
      Function[ BoxForm`e$, 
        MatrixForm[ BoxForm`e$]]]], "Output"],

Cell[BoxData[
    \({\((omega0 | kp | nu | Vt | tau)\) \[Element] Reals, Vt > 0, nu > 0, 
      tau \[GreaterEqual] 
        0, \((rl | ks | ht | hz | r0 | m0 | omc)\) \[Element] Reals, 
      rl \[GreaterEqual] 0, m0 > 0}\)], "Output"],

Cell[BoxData[
    RowBox[{\(General::"spell1"\), \(\(:\)\(\ \)\), "\<\"Possible spelling \
error: new symbol name \\\"\\!\\(mod\\)\\\" is similar to existing symbol \
\\\"\\!\\(Mod\\)\\\". \\!\\(\\*ButtonBox[\\\"More\[Ellipsis]\\\", \
ButtonStyle->\\\"RefGuideLinkText\\\", ButtonFrame->None, \
ButtonData:>\\\"General::spell1\\\"]\\)\"\>"}]], "Message"],

Cell[BoxData[
    RowBox[{\(General::"spell1"\), \(\(:\)\(\ \)\), "\<\"Possible spelling \
error: new symbol name \\\"\\!\\(arg\\)\\\" is similar to existing symbol \
\\\"\\!\\(Arg\\)\\\". \\!\\(\\*ButtonBox[\\\"More\[Ellipsis]\\\", \
ButtonStyle->\\\"RefGuideLinkText\\\", ButtonFrame->None, \
ButtonData:>\\\"General::spell1\\\"]\\)\"\>"}]], "Message"]
}, Open  ]],

Cell[BoxData[
    \(\(\( (*check\ for\ a\ matrix\ harm\ expressions*) \)\(\
\[IndentingNewLine]\)\(For[n = 0, \ n \[LessEqual] 5, \(n++\), 
        For[l = \(-1\), \ l \[LessEqual] 10, \(l++\), an = aFa[n, l]; 
          dev = FullSimplify[aF[n, l] - an]; \ 
          Print[{n, l, an, dev}];]];\)\)\)], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
    RowBox[{\( (*Integrals\ over\ Jperp*) \), "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{\(Jk[b_, 
              l_] := \((\(-1\))\)^
                b\ D[\(1/2\)/
                    a\ Exp[\(\(-\((p1^2 + p2^2 + q1^2 + q2^2)\)\)/4\)/a] 
                  BesselI[l, mod[p1, p2]\ \(mod[q1, q2]/2\)/a], {a, b}];\), 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{
          RowBox[{\(JqSS[b_, l_]\), ":=", 
            RowBox[{"Simplify", "[", 
              RowBox[{
                StyleBox["ReplaceAll",
                  "MR"], "[", \(\((m0\ omc)\)^\((b + 1)\)/2^b\ Jk[b, l], 
                a \[Rule] 1/2\ omc^2/\ Vt^2\), "]"}], "]"}]}], ";"}], 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{
          RowBox[{\(JqFS[b_, l_]\), ":=", 
            RowBox[{"FullSimplify", "[", 
              RowBox[{
                StyleBox["ReplaceAll",
                  "MR"], " ", "[", \(\((m0\ omc)\)^\((b + 1)\)/2^b\ Jk[b, l], 
                a \[Rule] 1/2\ omc^2/\ Vt^2\), "]"}], "]"}]}], ";"}], 
        "\[IndentingNewLine]", 
        "\[IndentingNewLine]", \(DDk[m_, n_, m1_, \ n1_, \ b_, \ l_] := 
            D[D[D[D[Exp[I\ l\ \((arg[p1, \ p2] - arg[q1, \ q2])\)]\ JqSS[b, 
                        l], {p2, n1}], {p1, m1}], {q2, n}], {q1, m}];\), 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{
          RowBox[{\(DD[m_, n_, m1_, \ n1_, \ b_, \ l_]\), ":=", " ", 
            RowBox[{"Simplify", "[", 
              RowBox[{
                StyleBox["ReplaceAll",
                  "MR"], " ", 
                "[", \(DDk[m, n, m1, \ n1, \ b, \ l], {q1 \[Rule] ks, \ 
                  q2 \[Rule] 0, p1 \[Rule] ks, \ p2 \[Rule] 0}\), "]"}], 
              "]"}]}], ";"}]}]}]], "Input"],

Cell[BoxData[
    RowBox[{\(General::"spell1"\), \(\(:\)\(\ \)\), "\<\"Possible spelling \
error: new symbol name \\\"\\!\\(JqFS\\)\\\" is similar to existing symbol \\\
\"\\!\\(JqSS\\)\\\". \\!\\(\\*ButtonBox[\\\"More\[Ellipsis]\\\", \
ButtonStyle->\\\"RefGuideLinkText\\\", ButtonFrame->None, \
ButtonData:>\\\"General::spell1\\\"]\\)\"\>"}]], "Message"],

Cell[BoxData[
    \(Null\^5\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    RowBox[{\( (*For\ direct\ evaluation\ of\ integrals\ over\ Jperp*) \), 
      "\[IndentingNewLine]", 
      RowBox[{\(Jt1k[m_, n_, \ l] := 
            D[D[Exp[I\ l\ arg[p1, \ p2]]\ BesselJ[l, mod[p1, p2]\ rl], {p2, 
                  n}], {p1, m}];\), "\[IndentingNewLine]", 
        "\[IndentingNewLine]", \(Jt2k[m_, n_, \ l] := 
            D[D[Exp[\(-I\)\ l\ arg[q1, \ q2]]\ BesselJ[l, 
                    mod[q1, q2]\ rl], {q2, n}], {q1, m}];\), 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{
          RowBox[{\(Jtt[m_, n_, \ m1_, n1_, b_, l_]\), ":=", 
            RowBox[{"Simplify", "[", 
              RowBox[{
                StyleBox["ReplaceAll",
                  "MR"], 
                StyleBox["[",
                  "MR"], 
                RowBox[{
                  RowBox[{
                    RowBox[{
                      StyleBox["Jt1k",
                        "MR"], "[", \(m1, n1, l\), "]"}], 
                    RowBox[{
                      StyleBox["Conjugate",
                        "MR"], 
                      StyleBox["[",
                        "MR"], \(Jt1k[m, \ n, l]\), "]"}], " ", \(J^b\), " ", 
                    
                    StyleBox[\(Exp[\(\(-omc\)/m0\)/Vt^2\ J]\),
                      "MR"]}], 
                  ",", \({q1 \[Rule] ks, \ q2 \[Rule] 0, p1 \[Rule] ks, \ 
                    p2 \[Rule] 0, \ rl \[Rule] Sqrt[2 \( J/m0\)/omc]}\)}], 
                "]"}], "]"}]}], ";"}]}]}]], "Input"],

Cell[BoxData[
    RowBox[{\(General::"spell1"\), \(\(:\)\(\ \)\), "\<\"Possible spelling \
error: new symbol name \\\"\\!\\(Jt1k\\)\\\" is similar to existing symbol \\\
\"\\!\\(J1k\\)\\\". \\!\\(\\*ButtonBox[\\\"More\[Ellipsis]\\\", ButtonStyle->\
\\\"RefGuideLinkText\\\", ButtonFrame->None, \
ButtonData:>\\\"General::spell1\\\"]\\)\"\>"}]], "Message"],

Cell[BoxData[
    \(Null\^3\)], "Output"]
}, Open  ]],

