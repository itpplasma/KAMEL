Cell[CellGroupData[{

Cell[BoxData[
    RowBox[{\( (*direct\ evaluation\ of\ D\ \(functions : \ 
            takes\ a\ lot\ of\ memory\ for\ N > \(3!\)\)*) \), 
      "\[IndentingNewLine]", 
      RowBox[{\(<< Algebra`Horner`;\), 
        "\[IndentingNewLine]", \(Dstrm = 
            OpenWrite["\</home/hare/KiLCA-CE/tensor/D3.t90\>"];\), "\n", 
        RowBox[{
          RowBox[{
            StyleBox["SetOptions",
              "MR"], 
            StyleBox["[",
              "MR"], 
            RowBox[{"Dstrm", 
              StyleBox[",",
                "MR"], " ", 
              RowBox[{
                StyleBox["FormatType",
                  "MR"], " ", "\[Rule]", " ", "OutputForm"}]}], 
            StyleBox["]",
              "MR"]}], " ", ";"}], "\n", \(Mmax\  = \ 1;\), 
        "\n", \(Nmax\  = \ 4;\), "\n", \(M1max\  = \ 1;\), 
        "\n", \(N1max\  = \ 4;\), "\n", \(Bmax\  = \ 1;\), 
        "\[IndentingNewLine]", 
        RowBox[{"(*", "\n", 
          RowBox[{
            RowBox[{"Write", 
              StyleBox["[",
                "MR"], 
              RowBox[{"Dstrm", ",", 
                StyleBox["\"\<subroutine calc_D_array(res)\>\"",
                  "MR"]}], "]"}], ";", "\n", 
            RowBox[{
              StyleBox["Write",
                "MR"], 
              StyleBox["[",
                "MR"], 
              RowBox[{"Dstrm", ",", " ", 
                StyleBox["\"\<\>\"",
                  "MR"]}], "]"}], ";", "\[IndentingNewLine]", 
            RowBox[{
              StyleBox["Write",
                "MR"], 
              StyleBox["[",
                "MR"], 
              RowBox[{"Dstrm", ",", 
                StyleBox["\"\<use constants, only: dpc, dp, vpc\>\"",
                  "MR"]}], "]"}], ";", "\n", 
            RowBox[{
              StyleBox["Write",
                "MR"], 
              StyleBox["[",
                "MR"], 
              RowBox[{"Dstrm", ",", 
                StyleBox["\"\<use conduct_parameters, only: D, \>\"",
                  "MR"]}], "]"}], ";", "\n", 
            RowBox[{
              StyleBox["Write",
                "MR"], 
              StyleBox["[",
                "MR"], 
              RowBox[{"Dstrm", ",", " ", 
                StyleBox["\"\<\>\"",
                  "MR"]}], "]"}], ";", "\[IndentingNewLine]", 
            RowBox[{
              StyleBox["Write",
                "MR"], 
              StyleBox["[",
                "MR"], 
              RowBox[{"Dstrm", ",", 
                StyleBox["\"\<implicit complex(vpc) (s-t)\>\"",
                  "MR"]}], "]"}], ";"}], "\n", "*)"}], "\[IndentingNewLine]", 
        
        RowBox[{
          RowBox[{
            StyleBox["Write",
              "MR"], 
            StyleBox["[",
              "MR"], 
            RowBox[{"Dstrm", ",", 
              
              StyleBox[\("\<!complex(dpc), dimension(0:\>" <> 
                  ToString[Mmax] <> "\<, 0:\>" <> 
                  ToString[Nmax] <> "\<, 0:\>" <> 
                  ToString[M1max] <> "\<, 0:\>" <> 
                  ToString[N1max] <> "\<, 0:\>" <> 
                  ToString[Bmax] <> "\<, -Nmax:Nmax) :: D\>"\),
                "MR"]}], "]"}], ";"}], "\n", 
        RowBox[{"(*", 
          RowBox[{
            RowBox[{
              StyleBox["Write",
                "MR"], 
              StyleBox["[",
                "MR"], 
              RowBox[{"Dstrm", ",", " ", 
                StyleBox["\"\<\>\"",
                  "MR"]}], "]"}], ";"}], "*)"}], "\[IndentingNewLine]", 
        "\[IndentingNewLine]", \( (*Get\ expressions\ for\ DD[m_, n_, m1_, \ 
              n1_, \ b_, \ l_]*) \), "\n", 
        RowBox[{
          RowBox[{"For", "[", 
            RowBox[{\(m = 0\), 
              StyleBox[",",
                "MR"], " ", \(m \[LessEqual] Mmax\), 
              StyleBox[",",
                "MR"], " ", \(m++\), ",", "\[IndentingNewLine]", 
              RowBox[{"For", "[", 
                RowBox[{\(n = 0\), 
                  StyleBox[",",
                    "MR"], " ", \(n \[LessEqual] Nmax\), 
                  StyleBox[",",
                    "MR"], " ", \(n++\), ",", "\[IndentingNewLine]", 
                  RowBox[{"For", "[", 
                    RowBox[{\(m1 = 0\), 
                      StyleBox[",",
                        "MR"], " ", \(m1 \[LessEqual] M1max\), 
                      StyleBox[",",
                        "MR"], " ", \(m1++\), ",", "\[IndentingNewLine]", 
                      RowBox[{"For", "[", 
                        RowBox[{\(n1 = 0\), 
                          StyleBox[",",
                            "MR"], " ", \(n1 \[LessEqual] N1max\), 
                          StyleBox[",",
                            "MR"], " ", \(n1++\), ",", "\[IndentingNewLine]", 
                          
                          RowBox[{"For", "[", 
                            RowBox[{\(d = 0\), 
                              StyleBox[",",
                                "MR"], " ", \(d \[LessEqual] Bmax\), 
                              StyleBox[",",
                                "MR"], " ", \(d++\), ",", 
                              "\[IndentingNewLine]", "\[IndentingNewLine]", 
                              
                              RowBox[{\(res = DD[m, n, m1, \ n1, \ d, \ l]\), 
                                ";", "\[IndentingNewLine]", \( (*\(Print[
                                      res];\)*) \), "\[IndentingNewLine]", 
                                "\[IndentingNewLine]", \(res = 
                                  Simplify[
                                    ReplaceRepeated[
                                      res, {BesselRule1, \ BesselRule2}]]\), 
                                ";", "\[IndentingNewLine]", \( (*\(Print[
                                      res];\)*) \), "\[IndentingNewLine]", 
                                "\[IndentingNewLine]", \(res\  = \ 
                                  ReplaceRepeated[
                                    res, \ {ks^2\ Vt^2/omc^2 \[Rule] \ x^2, \ 
                                      BesselI[l, x^2] \[Rule] B1, \ 
                                      BesselI[l + 1, x^2] \[Rule] B2, \ 
                                      Exp[\(-x^2\)] \[Rule] Ex}]\), ";", 
                                "\[IndentingNewLine]", 
                                "\[IndentingNewLine]", \(res\  = \ 
                                  ReplaceAll[
                                    res, \ {ks \[Rule] x\ omc/\ Vt}]\), ";", 
                                "\[IndentingNewLine]", 
                                "\[IndentingNewLine]", \(res\  = 
                                  Simplify[
                                    Map[Simplify, Collect[res, {x}]]]\), ";", 
                                "\[IndentingNewLine]", 
                                "\[IndentingNewLine]", \(facJ\  = 
                                  Simplify[\((m0\ omc)\)^\((d + 1)\) \((Vt^2/
                                        omc^2)\)^\((d + 1)\) \((Vt/
                                        omc)\)^\((m + n + m1 + n1)\) 
                                      Ex \((\(-I\))\)^\((n + n1)\)]\), ";", 
                                "\[IndentingNewLine]", \( (*\(Print[{m, n, 
                                        m1, n1, d, facJ}];\)*) \), "\n", "\t",
                                 "\[IndentingNewLine]", \(res = 
                                  facJ*Horner[
                                      Simplify[res/facJ], {x, B1, B2, l}]\), 
                                ";", "\[IndentingNewLine]", \(Print[res]\), 
                                ";", "\[IndentingNewLine]", 
                                "\[IndentingNewLine]", \(res\  = \ 
                                  ReplaceAll[
                                    res, \ {x \[Rule] x[1], Vt \[Rule] Vt[1], 
                                      omc \[Rule] omc[1], m0^2 -> m02, 
                                      l^2 \[Rule] l2}]\), ";", 
                                "\[IndentingNewLine]", \(res\  = \ 
                                  ReplaceAll[
                                    res, \ {Vt[1]^p_?Positive \[Rule] 
                                        Vt[p], \ 
                                      Vt[1]^p_?Negative \[Rule] 
                                        1/Vt[\(-p\)]}]\), 
                                ";", \(res\  = \ 
                                  ReplaceAll[
                                    res, \ {x[1]^p_?Positive \[Rule] x[p], \ 
                                      x[1]^p_?Negative \[Rule] 
                                        1/x[\(-p\)]}]\), 
                                ";", \(res\  = \ 
                                  ReplaceAll[
                                    res, \ {omc[1]^p_?Positive \[Rule] 
                                        omc[p], \ 
                                      omc[1]^p_?Negative \[Rule] 
                                        1/omc[\(-p\)]}]\), ";", 
                                "\[IndentingNewLine]", \(Print[res]\), ";", 
                                "\[IndentingNewLine]", "\[IndentingNewLine]", 
                                
                                RowBox[{
                                  StyleBox["SetOptions",
                                    "MR"], 
                                  StyleBox["[",
                                    "MR"], 
                                  RowBox[{"Dstrm", ",", " ", 
                                    RowBox[{
                                      StyleBox["FormatType",
                                        "MR"], " ", "\[Rule]", " ", 
                                      "OutputForm"}]}], 
                                  StyleBox["]",
                                    "MR"]}], " ", ";", " ", 
                                "\[IndentingNewLine]", 
                                RowBox[{
                                  StyleBox["Write",
                                    "MR"], 
                                  StyleBox["[",
                                    "MR"], \(Dstrm, "\<\>"\), "]"}], ";", 
                                "\[IndentingNewLine]", 
                                RowBox[{
                                  StyleBox["Write",
                                    "MR"], 
                                  StyleBox["[",
                                    "MR"], \(Dstrm, "\<D(\>", m, "\<,\>", 
                                  n, "\<,\>", m1, "\<,\>", n1, "\<,\>", 
                                  d, "\<,l) = \>"\), "]"}], ";", 
                                "\[IndentingNewLine]", 
                                RowBox[{
                                  StyleBox["SetOptions",
                                    "MR"], 
                                  StyleBox["[",
                                    "MR"], 
                                  RowBox[{"Dstrm", 
                                    StyleBox[",",
                                      "MR"], " ", 
                                    RowBox[{
                                      StyleBox["FormatType",
                                        "MR"], " ", "\[Rule]", " ", 
                                      "InputForm"}]}], 
                                  StyleBox["]",
                                    "MR"]}], " ", ";", "\[IndentingNewLine]", 
                                
                                RowBox[{
                                  StyleBox["Write",
                                    "MR"], 
                                  StyleBox["[",
                                    "MR"], \(Dstrm, res\), "]"}], ";"}]}], 
                            "]"}]}], "]"}]}], "]"}]}], "]"}]}], "]"}], ";"}], 
        "\[IndentingNewLine]", 
        RowBox[{"(*", "\[IndentingNewLine]", 
          RowBox[{
            RowBox[{
              StyleBox["SetOptions",
                "MR"], 
              StyleBox["[",
                "MR"], 
              RowBox[{"Dstrm", 
                StyleBox[",",
                  "MR"], " ", 
                RowBox[{
                  StyleBox["FormatType",
                    "MR"], " ", "\[Rule]", " ", "OutputForm"}]}], 
              StyleBox["]",
                "MR"]}], " ", ";", "\[IndentingNewLine]", 
            RowBox[{"Write", 
              StyleBox["[",
                "MR"], 
              RowBox[{"Dstrm", ",", 
                StyleBox["\"\<\>\"",
                  "MR"]}], "]"}], ";", "\[IndentingNewLine]", 
            RowBox[{"Write", 
              StyleBox["[",
                "MR"], 
              RowBox[{"Dstrm", ",", 
                StyleBox["\"\<end subroutine\>\"",
                  "MR"]}], "]"}], ";"}], "\[IndentingNewLine]", "*)"}], 
        "\[IndentingNewLine]", \(Close[Dstrm];\), 
        "\[IndentingNewLine]", \(Clear[m, n, m1, n1, d, \ Mmax, \ Nmax, 
            M1max, N1max];\)}]}]], "Input"],

