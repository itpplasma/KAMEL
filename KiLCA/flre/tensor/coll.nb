Cell[BoxData[{\(<< Algebra`Horner`;\), "\n", \(Dstrm = 
        OpenWrite["\</home/hare/KiLCA-CE/tensor/W2_.t90\>"];\), "\n", 
    RowBox[{
      RowBox[{
        StyleBox["SetOptions",
          "MR"], 
        StyleBox["[",
          "MR"], 
        RowBox[{"Dstrm", 
          StyleBox[",",
            "MR"], " ", 
          RowBox[{
            StyleBox["FormatType",
              "MR"], " ", "\[Rule]", " ", "OutputForm"}]}], 
        StyleBox["]",
          "MR"]}], " ", 
      ";"}], "\n", \(Mumax\  = \ 1;\), "\n", \(Numax\  = \ 3;\), "\n", 
    RowBox[{
      RowBox[{
        RowBox[{
          StyleBox["Write",
            "MR"], 
          StyleBox["[",
            "MR"], 
          RowBox[{"Dstrm", ",", 
            
            StyleBox[\("\<!complex(dpc), dimension(0:\>" <> 
                ToString[Mumax] <> "\<, 0:\>" <> 
                ToString[Numax] <> \ "\<, -Nmax:Nmax) :: W2\>"\),
              "MR"]}], "]"}], ";"}], "\n", 
      "\n", \( (*Get\ expressions\ for\ W2[m_, n]*) \)}], "\n", 
    RowBox[{
      RowBox[{"For", "[", 
        RowBox[{\(m = 0\), 
          StyleBox[",",
            "MR"], " ", \(m \[LessEqual] Mumax\), 
          StyleBox[",",
            "MR"], " ", \(m++\), ",", "\[IndentingNewLine]", 
          RowBox[{"For", "[", 
            RowBox[{\(n = 0\), 
              StyleBox[",",
                "MR"], " ", \(n \[LessEqual] Numax\), 
              StyleBox[",",
                "MR"], " ", \(n++\), ",", "\[IndentingNewLine]", 
              "\[IndentingNewLine]", 
              
              RowBox[{\(res = J1der[m, \ n, nu]\), ";", 
                "\[IndentingNewLine]", \( (*\(Print[res];\)*) \), 
                "\[IndentingNewLine]", 
                "\[IndentingNewLine]", \(res\  = \ 
                  ReplaceRepeated[
                    res, \ {Sqrt[2\ Pi] \[Rule] sqrt2p, 
                      kp^2\ Vt^2/nu^2 \[Rule] \ 
                        t1, \((\(-\[ImaginaryI]\)\ nu\ \((omega - omega0)\) + 
                              kp^2\ Vt^2)\)/nu^2 \[Rule] 
                        t2\ , \((\[ImaginaryI]\ nu\ \((omega - omega0)\) - 
                              kp^2\ Vt^2)\)/nu^2 \[Rule] \(-t2\), 
                      Gamma[t2] -> Gamma[t2, t1] + gam, Exp[t1] \[Rule] Ex, 
                      t1^\((\(-t2\))\) \[Rule] 1/t1Pt2, 
                      omega - omega0 \[Rule] dom}]\), ";", 
                "\[IndentingNewLine]", 
                "\[IndentingNewLine]", \(res\  = \ 
                  Simplify[
                    ReplaceAll[res, \ {gam \[Rule] 1/Ex\ t1Pt2\ /t2\ F11}]]\),
                 ";", "\[IndentingNewLine]", 
                "\[IndentingNewLine]", \(Print[res]\), ";", 
                "\[IndentingNewLine]", 
                "\[IndentingNewLine]", \(res\  = \ 
                  Simplify[
                    ReplaceRepeated[
                      res, \ {\ 
                        F11 \[Rule] 
                          1 + t1/\((1 + 
                                  t2)\) + \(t1^2/\((1 + t2)\)\)/\((t2 + 
                                    2)\) \((1 + F11m)\), \ 
                        t2 \[Rule] t1 - I\ dom/nu, t1 -> kp^2\ Vt^2/nu^2, 
                        omega \[Rule] dom + omega0}]]\), ";", 
                "\[IndentingNewLine]", 
                "\[IndentingNewLine]", \( (*\(res\  = \ 
                      Simplify[Map[Simplify, Horner[res, {dom}]]];\)*) \), 
                "\[IndentingNewLine]", 
                "\[IndentingNewLine]", \(W2arr[m, n] = res\), ";", 
                "\[IndentingNewLine]", 
                "\[IndentingNewLine]", \(res\  = \ 
                  ReplaceAll[
                    res, \ {Vt \[Rule] Vt[1], kp \[Rule] kp[1], 
                      dom \[Rule] dom[1], \ nu \[Rule] nu[1]}]\), 
                ";", \(res\  = \ 
                  ReplaceAll[
                    res, \ {kp[1]^p_?Positive \[Rule] kp[p], \ 
                      kp[1]^p_?Negative \[Rule] 1/kp[\(-p\)]}]\), ";", 
                "\[IndentingNewLine]", \(res\  = \ 
                  ReplaceAll[
                    res, \ {Vt[1]^p_?Positive \[Rule] Vt[p], \ 
                      Vt[1]^p_?Negative \[Rule] 1/Vt[\(-p\)]}]\), ";", 
                "\[IndentingNewLine]", \(res\  = \ 
                  ReplaceAll[
                    res, \ {dom[1]^p_?Positive \[Rule] dom[p], \ 
                      dom[1]^p_?Negative \[Rule] 1/dom[\(-p\)]}]\), ";", 
                "\[IndentingNewLine]", \(res\  = \ 
                  ReplaceAll[
                    res, \ {nu[1]^p_?Positive \[Rule] nu[p], \ 
                      nu[1]^p_?Negative \[Rule] 1/nu[\(-p\)]}]\), ";", 
                "\[IndentingNewLine]", "\[IndentingNewLine]", \(Print[res]\), 
                ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
                RowBox[{
                  StyleBox["SetOptions",
                    "MR"], 
                  StyleBox["[",
                    "MR"], 
                  RowBox[{"Dstrm", ",", " ", 
                    RowBox[{
                      StyleBox["FormatType",
                        "MR"], " ", "\[Rule]", " ", "OutputForm"}]}], 
                  StyleBox["]",
                    "MR"]}], " ", ";", " ", "\[IndentingNewLine]", 
                RowBox[{
                  StyleBox["Write",
                    "MR"], 
                  StyleBox["[",
                    "MR"], \(Dstrm, "\<\>"\), "]"}], ";", 
                "\[IndentingNewLine]", 
                RowBox[{
                  StyleBox["Write",
                    "MR"], 
                  StyleBox["[",
                    "MR"], \(Dstrm, "\<W2(\>", m, "\<,\>", n, "\<,l) = \>"\), 
                  "]"}], ";", "\[IndentingNewLine]", 
