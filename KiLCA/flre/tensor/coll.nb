                ";", "\[IndentingNewLine]", 
                "\[IndentingNewLine]", \(res\  = \ 
                  ReplaceAll[res, \ {z \[Rule] z[1]}]\), ";", 
                "\[IndentingNewLine]", \(res\  = \ Expand[res, z]\), ";", 
                "\[IndentingNewLine]", \(res\  = \ 
                  ReplaceAll[
                    res, \ {z[1]^p_?Positive \[Rule] z[p], \ 
                      z[1]^p_?Negative \[Rule] z[p]}]\), ";", 
                "\[IndentingNewLine]", \(res\  = \ 
                  ReplaceAll[
                    res, \ {Vt[1]^p_?Positive \[Rule] Vt[p], \ 
                      Vt[1]^p_?Negative \[Rule] 1/Vt[\(-p\)]}]\), ";", 
                "\[IndentingNewLine]", \(res\  = \ FullSimplify[res]\), ";", 
                "\[IndentingNewLine]", \(Print[m, "\<, \>", n, "\<, \>", 
                  res]\), ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
