Cell[BoxData[{
    RowBox[{
      RowBox[{"BesselRule1", "=", 
        RowBox[{
          RowBox[{"BesselI", "[", 
            RowBox[{
              RowBox[{
                RowBox[{"(", 
                  RowBox[{"in_Integer", " ", 
                    StyleBox["/;",
                      "MR"], " ", 
                    RowBox[{"in", " ", 
                      StyleBox[">",
                        "MR"], " ", "1"}]}], ")"}], " ", "+", "l"}], ",", 
              "z_"}], "]"}], 
          "->", \(BesselI[l + in - 2, z] - 
            2\ \((l + in - 1)\)/z\ BesselI[l + in - 1, z]\)}]}], 
      "\n"}], "\[IndentingNewLine]", 
    RowBox[{
      RowBox[{"BesselRule2", "=", 
        RowBox[{
          RowBox[{"BesselI", "[", 
            RowBox[{
              RowBox[{
                RowBox[{"(", 
                  RowBox[{"in_Integer", " ", 
                    StyleBox["/;",
                      "MR"], " ", \(in\  < 0\)}], ")"}], " ", "+", "l"}], ",",
               "z_"}], "]"}], 
          "->", \(BesselI[l + in + 2, z] + 
            2\ \((l + in + 1)\)/z\ BesselI[l + in + 1, z]\)}]}], 
      "\[IndentingNewLine]", 
      "\[IndentingNewLine]", \( (*\(check\)\(:\)*) \)}], \
"\[IndentingNewLine]", \(expr = \ 
      BesselI[l - 10, z] + BesselI[l + 9, z] + 
        BesselI[l, z]\), "\[IndentingNewLine]", \(tst = 
      Simplify[ReplaceRepeated[
          expr, {BesselRule1, \ 
            BesselRule2}]]\), "\[IndentingNewLine]", \(FullSimplify[
      tst - expr]\)}], "Input"],

