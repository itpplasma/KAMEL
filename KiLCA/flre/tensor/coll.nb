Cell[BoxData[
    \(\(\( (*J1[m, n]\ \(array : \ 
          symmetric\ over\ \((m, n)\)\)*) \)\(\[IndentingNewLine]\)\(For[
        m = 0, \ m \[LessEqual] 1, \(m++\), 
        For[n = 0, \ n \[LessEqual] 3, \(n++\), 
          J1v[m, n] = J1ana[m, n, \ nu]; 
          dev = FullSimplify[J1v[m, n]\  - J1exa[m, n, \ nu]]; \ 
          Print[{m, n, J1v[m, n], dev}];]];\)\)\)], "Input"],

Cell[BoxData[
    RowBox[{\( (*check\ of\ the\ W2\ function*) \), "\[IndentingNewLine]", 
      RowBox[{
        RowBox[{\(J1exaWTW[m_, n_, \ nu_]\), ":=", 
          RowBox[{"Integrate", "[", 
            RowBox[{
              RowBox[{\(w1^m\), " ", 
                RowBox[{
                  StyleBox["Integrate",
                    "MR"], 
                  StyleBox["[",
                    "MR"], " ", 
                  RowBox[{
                    RowBox[{\(G[w1, \ w2, tau, \ nu]\), 
                      StyleBox[\(w2^n\),
                        "MR"], 
                      StyleBox[" ",
                        "MR"], 
                      StyleBox[\(Exp[\(\(-w2^2\)/2\)/Vt^2]\),
                        "MR"]}], 
                    StyleBox[",",
                      "MR"], 
                    RowBox[{
                      StyleBox["{",
                        "MR"], 
                      RowBox[{
                        StyleBox["w2",
