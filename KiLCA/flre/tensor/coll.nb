                    "MR"], 
                  StyleBox["[",
                    "MR"], \(Dstrm, res\), "]"}], ";"}]}], "]"}]}], "]"}], 
      ";"}], "\n", \(Close[Dstrm];\), "\n", \(Clear[m, n, Mumax, \ 
        Numax];\)}], "Input"],

