Cell[CellGroupData[{

Cell[BoxData[
    \(\(\( (*J1\ \(\(expressions\)\(:\)\)*) \)\(\[IndentingNewLine]\)\(\(AA[
          nu_] := I \((omega - omega0)\) - 
          kp^2\ Vt^2/nu;\)\[IndentingNewLine]\[IndentingNewLine]
    \(BB[alpha_, \ beta_, \ nu_] := 
        Vt^2 \((\ alpha\  + \ I\ kp/nu)\) \((\ 
            beta + \ I\ kp/nu)\);\)\[IndentingNewLine]\n
    \(CC[alpha_, \ beta_, \ nu_] := 
        Vt^2/2 \((alpha^2 + beta^2)\) - 
          I\ kp\ /nu\ Vt^2\ \((alpha + beta)\)\  + \ 
          kp^2\ Vt^2/nu^2;\)\[IndentingNewLine]\[IndentingNewLine]
    \(gamma[a_, z_] := 
        Gamma[a] - Gamma[a, z];\)\[IndentingNewLine]\[IndentingNewLine]
    \(J1k[alpha_, \ beta_, tau_, nu_] := 
        Sqrt[2\ Pi]\ Vt\ Exp[
            CC[alpha, \ beta, \ nu] + 
              BB[alpha, \ beta, \ nu]\ Exp[\(-nu\)\ tau]\  + 
              AA[nu]\ tau];\)\[IndentingNewLine]\n
    \(J1s[m_, \ n_, tau_, nu_] := 
        FullSimplify[
          ReplaceAll[
            D[D[J1k[alpha, \ beta, tau, nu], {beta, n}], {alpha, 
                m}], {alpha \[Rule] 0, \ 
              beta\  \[Rule] \ 0}]];\)\[IndentingNewLine]\[IndentingNewLine]
    \(J1ana[m_, \ n_, nu_] := 
        FullSimplify[
          Integrate[
            J1s[m, \ n, tau, nu], {tau, \ 0, \ 
              Infinity}]];\)\[IndentingNewLine]\[IndentingNewLine]
    \(J1d[m_, \ n_, alpha_, \ beta_, \ nu_] := 
        Sqrt[2\ Pi]\ Vt\ D[
            D[Exp[CC[alpha, \ beta, \ nu]]/
                  nu\ \ Power[\(-BB[alpha, \ beta, \ nu]\), 
                  AA[nu]/nu]\ gamma[\(-\ AA[nu]\)/
                    nu, \(-BB[alpha, \ beta, \ nu]\)], {alpha, m}], {beta, 
              n}];\)\[IndentingNewLine]\[IndentingNewLine]
    \(J1der[m_, \ n_, nu_] := \ 
        FullSimplify[
          ReplaceAll[
            J1d[m, \ n, alpha, \ beta, \ nu], {alpha \[Rule] 0, \ 
              beta \[Rule] 
                0}]];\)\[IndentingNewLine]\[IndentingNewLine] (*\(W2[m_, \ 
            n_] := J1ana[m, \ n, nu];\)*) \[IndentingNewLine]
    \(W2[m_, \ n_] := J1der[m, \ n, nu];\)\)\)\)], "Input"],

Cell[BoxData[
    RowBox[{\(General::"spell1"\), \(\(:\)\(\ \)\), "\<\"Possible spelling \
error: new symbol name \\\"\\!\\(gamma\\)\\\" is similar to existing symbol \
\\\"\\!\\(Gamma\\)\\\". \\!\\(\\*ButtonBox[\\\"More\[Ellipsis]\\\", \
ButtonStyle->\\\"RefGuideLinkText\\\", ButtonFrame->None, \
ButtonData:>\\\"General::spell1\\\"]\\)\"\>"}]], "Message"]
}, Open  ]],

