Cell[CellGroupData[{

Cell[BoxData[{\(IGammaRule = 
      Gamma[a_ + n_Integer, z_] -> 
        z^\((a + n - 1)\)\ Exp[\(-z\)] + \((a + n - 1)\)\ Gamma[a + n - 1, 
              z]\), "\n", \(GammaRule = 
      Gamma[z_ + n_Integer] \[Rule] \((z + n - 1)\)\ Gamma[
            z + n - 1]\), "\[IndentingNewLine]", 
    RowBox[{
      RowBox[{"(*", 
        RowBox[{"IgammaRule", "=", 
          RowBox[{\(gamma[a_, z_]\), "->", 
            RowBox[{\(z^a/a\), " ", \(Exp[\(-z\)]\), 
              RowBox[{
                StyleBox["Hypergeometric1F1",
                  "MR"], 
                StyleBox["[",
                  "MR"], 
                RowBox[{
                  StyleBox["1",
                    "MR"], 
                  StyleBox[",",
                    "MR"], " ", \(1 + a\), 
                  StyleBox[",",
                    "MR"], " ", 
                  StyleBox["z",
                    "TI"]}], 
                StyleBox["]",
                  "MR"]}]}]}]}], 
        StyleBox["*)",
          "MR"]}]}]}], "Input"],

Cell[BoxData[
    \(Gamma[a_ + n_Integer, 
        z_] \[Rule] \[ExponentialE]\^\(-z\)\ z\^\(\(-1\) + a + n\) + \
\((\(-1\) + a + n)\)\ Gamma[\(-1\) + a + n, z]\)], "Output"],

Cell[BoxData[
    RowBox[{\(General::"spell1"\), \(\(:\)\(\ \)\), "\<\"Possible spelling \
error: new symbol name \\\"\\!\\(GammaRule\\)\\\" is similar to existing \
symbol \\\"\\!\\(IGammaRule\\)\\\". \
\\!\\(\\*ButtonBox[\\\"More\[Ellipsis]\\\", ButtonStyle->\\\"RefGuideLinkText\
\\\", ButtonFrame->None, ButtonData:>\\\"General::spell1\\\"]\\)\"\>"}]], \
"Message"],

Cell[BoxData[
    \(Gamma[
        n_Integer + 
          z_] \[Rule] \((\(-1\) + n + z)\)\ Gamma[\(-1\) + n + z]\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[{
    \(\(\(res = J1der[0, \ 2, nu]\)\(\[IndentingNewLine]\)
    \)\), "\[IndentingNewLine]", 
    \(\(\(res\  = \ 
        ReplaceRepeated[
          res, \ {Sqrt[2\ Pi] \[Rule] sqrt2p, 
            kp^2\ Vt^2/nu^2 \[Rule] \ 
              t1, \((\(-\[ImaginaryI]\)\ nu\ \((omega - omega0)\) + 
                    kp^2\ Vt^2)\)/nu^2 \[Rule] 
              t2\ , \((\[ImaginaryI]\ nu\ \((omega - omega0)\) - 
                    kp^2\ Vt^2)\)/nu^2 \[Rule] \(-t2\), 
            Gamma[t2] -> Gamma[t2, t1] + gam, Exp[t1] \[Rule] Ex, 
            t1^\((\(-t2\))\) \[Rule] 1/t1Pt2, 
            omega - omega0 \[Rule] dom}];\)\(\[IndentingNewLine]\)
    \)\), "\[IndentingNewLine]", 
    \(\(\(res\  = \ 
      Simplify[ReplaceAll[
          res, \ {gam \[Rule] 1/Ex\ t1Pt2\ /t2\ F11, 
            omega \[Rule] dom + omega0}]]\)\(\[IndentingNewLine]\)
    \)\), "\[IndentingNewLine]", 
    \(\(\(res\  = \ 
      Simplify[ReplaceRepeated[
          res, \ {\ 
            F11 \[Rule] 
              1 + t1/\((1 + t2)\) + \(t1^2/\((1 + t2)\)\)/\((t2 + 2)\) \((1 + 
                      F11m)\), \ t2 \[Rule] t1 - I\ dom/nu, 
            t1 -> kp^2\ Vt^2/
                  nu^2}]]\)\(\[IndentingNewLine]\)\(\[IndentingNewLine]\)\(\
\[IndentingNewLine]\)
    \) (*\(res\  = \ 
          Simplify[
            Map[Simplify, 
              Horner[res, {kp, nu, dom}]]];\)*) \), "\[IndentingNewLine]", 
    \(\)}], "Input"],

Cell[BoxData[
    \(\(1\/kp\^2\) \((\@\(2\ \[Pi]\)\ Vt\ \((nu - \[ImaginaryI]\ omega + \
\[ImaginaryI]\ omega0 + \(1\/nu\) \((\[ExponentialE]\^\(\(kp\^2\ \
Vt\^2\)\/nu\^2\)\ \((omega - omega0)\)\ \((\[ImaginaryI]\ nu + omega - 
                        omega0)\)\ \((\(kp\^2\ Vt\^2\)\/nu\^2)\)\^\(\(\
\[ImaginaryI]\ nu\ \((omega - omega0)\) - kp\^2\ Vt\^2\)\/nu\^2\)\ \
\((Gamma[\(\(-\[ImaginaryI]\)\ nu\ \((omega - omega0)\) + kp\^2\ \
Vt\^2\)\/nu\^2] - 
                        Gamma[\(\(-\[ImaginaryI]\)\ nu\ \((omega - omega0)\) \
+ kp\^2\ Vt\^2\)\/nu\^2, \(kp\^2\ Vt\^2\)\/nu\^2])\))\))\))\)\)], "Output"],

Cell[BoxData[
    \(\(\((dom + \[ImaginaryI]\ nu)\)\ sqrt2p\ \((dom\ F11 - \[ImaginaryI]\ \
nu\ t2)\)\ Vt\)\/\(kp\^2\ nu\ t2\)\)], "Output"],

Cell[BoxData[
    \(\(-\(\(\[ImaginaryI]\ \((dom + \[ImaginaryI]\ nu)\)\ sqrt2p\ Vt\^3\ \
\((dom\ \((\(-nu\^3\) + 
                      F11m\ kp\^2\ nu\ Vt\^2)\) - \[ImaginaryI]\ \((2\ nu\^4 \
+ 3\ kp\^2\ nu\^2\ Vt\^2 + 
                      kp\^4\ Vt\^4)\))\)\)\/\(\((dom\ nu + \[ImaginaryI]\ \
kp\^2\ Vt\^2)\)\ \((dom\ nu + \[ImaginaryI]\ \((nu\^2 + 
                      kp\^2\ Vt\^2)\))\)\ \((dom\ nu + \[ImaginaryI]\ \((2\ \
nu\^2 + kp\^2\ Vt\^2)\))\)\)\)\)\)], "Output"]
}, Open  ]],

