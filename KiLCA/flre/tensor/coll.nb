Cell[BoxData[{\(F11as[b_, 
          z_] := \(-\((b - 1)\)\)/z\ Sum[
              Pochhammer[2 - b, n]/\((\(-z\))\)^n, {n, 0, 50}] + 
          Gamma[b] Exp[z] z^\((1 - b)\);\), "\[IndentingNewLine]", 
    RowBox[{
      RowBox[{\(F11in[b_, z_]\), ":=", 
        RowBox[{\((b - 1)\), 
          RowBox[{"NIntegrate", "[", 
            
            RowBox[{\(Exp[z\ t] \((1 - t)\)^\((b - 2)\)\), ",", \({t, 0, 1}\),
               ",", 
              StyleBox[\(AccuracyGoal -> 50\),
                "MR"]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
    RowBox[{
      RowBox[{\(F11ku[b_, z_]\), ":=", " ", 
        RowBox[{"Sum", "[", 
          RowBox[{\(z^n\ /Pochhammer[b, n]\), ",", 
            RowBox[{"{", 
              RowBox[{"n", ",", "0", ",", 
                RowBox[{
                  StyleBox["Ceiling",
                    "MR"], 
                  StyleBox["[",
                    "MR"], 
                  RowBox[{
                    StyleBox["Abs",
                      "MR"], 
                    StyleBox["[",
                      "MR"], \(\(-20\)/Log[10, z/b]\), "]"}], "]"}]}], 
              "}"}]}], "]"}]}], ";"}]}], "Input"],

Cell[CellGroupData[{

Cell[BoxData[{\(z = \ 
        22030755774330544227\ 10^5/10^20;\), "\[IndentingNewLine]", 
    RowBox[{\(b = 1 + z - 39812023159305316433  I/10^19;\), 
      "\[IndentingNewLine]", \( (*z = 1.873359\ 10^4\  + I\ 1.37775110^4*) \),
       "\[IndentingNewLine]", \( (*ra = 
          N[F11as[b, z], 20]*) \)}], "\[IndentingNewLine]", 
    RowBox[{
      RowBox[{"re", "=", 
        RowBox[{"N", "[", 
          RowBox[{
            RowBox[{
              RowBox[{
                RowBox[{"(", 
                  RowBox[{
                    RowBox[{
                      StyleBox["Hypergeometric1F1",
                        "MR"], 
                      StyleBox["[",
                        "MR"], 
                      RowBox[{
                        StyleBox["1",
                          "MR"], 
                        StyleBox[",",
                          "MR"], " ", 
                        StyleBox["b",
                          "TI"], 
                        StyleBox[",",
                          "MR"], " ", 
                        StyleBox["z",
                          "TI"]}], 
                      StyleBox["]",
                        "MR"]}], 
                    StyleBox["-",
                      "MR"], 
                    StyleBox["1",
                      "MR"], 
                    StyleBox["-",
                      "MR"], 
                    StyleBox[\(z/b\),
                      "MR"]}], 
                  StyleBox[")",
                    "MR"]}], 
                StyleBox["*",
                  "MR"], 
                StyleBox["b",
                  "MR"], 
                StyleBox["*",
                  "MR"], 
                StyleBox[\(\((b + 1)\)/z^2\),
                  "MR"]}], 
              StyleBox["-",
