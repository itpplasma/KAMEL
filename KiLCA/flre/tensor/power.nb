 RowBox[{
  FractionBox["1", "nu"], 
  RowBox[{
   SuperscriptBox["\[ExponentialE]", 
    FractionBox[
     RowBox[{
      SuperscriptBox["kp", "2"], " ", 
      SuperscriptBox["Vt", "2"]}], 
     SuperscriptBox["nu", "2"]]], " ", 
   SqrtBox[
    RowBox[{"2", " ", "\[Pi]"}]], " ", "Vt", " ", 
   RowBox[{"Re", "[", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       FractionBox[
        RowBox[{"kp", " ", "Vt"}], "nu"], ")"}], 
      FractionBox[
       RowBox[{"2", " ", "\[ImaginaryI]", " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"nu", " ", 
           RowBox[{"(", 
            RowBox[{"omega", "-", "omega0"}], ")"}]}], "+", 
          RowBox[{"\[ImaginaryI]", " ", 
           SuperscriptBox["kp", "2"], " ", 
           SuperscriptBox["Vt", "2"]}]}], ")"}]}], 
       SuperscriptBox["nu", "2"]]], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Gamma", "[", 
        FractionBox[
         RowBox[{
          RowBox[{
           RowBox[{"-", "\[ImaginaryI]"}], " ", "nu", " ", 
           RowBox[{"(", 
            RowBox[{"omega", "-", "omega0"}], ")"}]}], "+", 
          RowBox[{
           SuperscriptBox["kp", "2"], " ", 
           SuperscriptBox["Vt", "2"]}]}], 
         SuperscriptBox["nu", "2"]], "]"}], "-", 
       RowBox[{"Gamma", "[", 
