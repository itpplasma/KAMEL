# full path to the ZerSol top level directory:
ROOT_PATH = /home/hare/ivi/zersol

# CPP compiler options:
CXX = g++
CXXFLAGS = -I$(SRC_INC) -O2 -mtune=generic -Wall -Wshadow -Wclobbered -Wempty-body -Wignored-qualifiers -Wmissing-field-initializers -Wsign-compare -Wtype-limits -Wuninitialized -Wunused-but-set-parameter

# C compiler options:
CC = gcc
CFLAGS  = -I$(SRC_INC) -O2 -mtune=generic -Wall -Wshadow -Wclobbered -Wempty-body -Wignored-qualifiers -Wmissing-field-initializers -Wsign-compare -Wtype-limits -Wuninitialized -Wunused-but-set-parameter

# Fortran compiler options:
FC = gfortran
FFLAGS = -ffree-form -O2 -Wall -Wextra -Wshadow -mtune=generic

# Linker options:
LDFLAGS =

# Archiving options:
AR = ar -crs

# include directories:
SRC_INC = $(ROOT_PATH)/src

# Below settings for compiling and building are automatically selected depending on $(lang) variable passed to make.
# To build bindings or a test case call the make in the respective directory:
# make lang=c++ or make lang=c or make lang=fortran
ifeq ($(lang), c++)
	suf = cpp
	COMP = $(CXX)
	COMPOPTS = $(CXXFLAGS)
else
	ifeq ($(lang), c)
		suf = c
		COMP = $(CC)
		COMPOPTS = $(CFLAGS)
		LDFLAGS = -L$(ROOT_PATH)/lib -lzersol$(suf) -lm -lstdc++ -static
	else
		ifeq ($(lang), fortran)
			suf = f
			COMP = $(FC)
			COMPOPTS = $(FFLAGS)
			LDFLAGS = -L$(ROOT_PATH)/lib -lzersol$(suf) -lstdc++ -static
		else
			ifeq ($(lang), matlab)
				suf = m
				COMP = $(CC)
				COMPOPTS = $(CFLAGS)
				LDFLAGS = -L$(ROOT_PATH)/lib -lzersol$(suf) -lm -lstdc++ -static
			endif
		endif
	endif
endif
