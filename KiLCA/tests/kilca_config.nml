&background
    ! Machine settings
    rtor = 165 ! big torus radius (cm) of the machine: default=none
    rp = 67 ! plasma radius (cm)
    B0 = -17977.413 ! toroidal magnetic field (G) at the center: default=2.0e4

    ! Background settings
    path2profiles = "./profiles/" ! path to input background profiles: default=./profiles/
    calc_back = 1 ! 1 - if background must be recalculated (7 input profiles are needed), 0 - otherwise (11 input profiles are needed), -1 - from interface
    flag_back = "f" ! flag for background ('f'-full, 'w'-wkb, 'h'-hom): default=f
    N = 9 ! splines degree: >= NC + 2N+1, where N - order of flr expansion, NC - spl degree for C matrices, must be odd!!!
    V_gal_sys = -1e8 ! velocity (cm/c) of moving frame: default=-0.5e7
    V_scale = 1 ! scale factor for the Vz velocity profile: Vz = V_scale*Vz - V_gal_sys
    m_i = 2 ! ions mass in units of proton mass: default=2
    zele = 1 ! collisions coefficient for electrons: default=1.0
    zion = 1 ! collisions coefficient for ions: default=1.0

    ! Debug setting
    flag_debug = .false. ! flag for debugging mode (additional checks are performed in the code): default=.true.
&end
