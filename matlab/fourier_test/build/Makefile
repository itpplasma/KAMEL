	$(MAKE) $(MAKESILENT) -f CMakeFiles/mc_efit.dir/build.make CMakeFiles/mc_efit.dir/src/theta_rz_mod.f90.i
.PHONY : src/theta_rz_mod.f90.i

src/theta_rz_mod.s: src/theta_rz_mod.f90.s

.PHONY : src/theta_rz_mod.s

# target to generate assembly for a file
src/theta_rz_mod.f90.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/mc_efit.dir/build.make CMakeFiles/mc_efit.dir/src/theta_rz_mod.f90.s
.PHONY : src/theta_rz_mod.f90.s

