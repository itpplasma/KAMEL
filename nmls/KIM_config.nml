&kim_config
    profile_location = './profiles/'
    output_path = './out/'
    hdf5_input = .false.
    hdf5_output = .false.
    fdebug = 1
    fstatus = 1
    ispecies = 1
/

&kim_setup
    btor = -17977.413
    r0 = 165.0
    m_mode = 7
    n_mode = 2
    zi = 1
    ai = 2
    r_plas = 64.7
    k_space_dim = 100
    l_space_dim = 100
    reduce_r = .false.
    reduced_r_dim = 100
    omega = 0.0
    spline_base = 1
    grid_spacing = 2
    cut_off_fac = 1.0
    num_gengrid_points = 512
/
