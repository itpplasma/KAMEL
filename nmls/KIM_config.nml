&KIM_CONFIG
 profile_location = './profiles/' , ! path to profiles (either text or hdf5)
 output_path      = './out/'      , ! output path
 hdf5_input       = F , ! read input from hdf5 input if true
 hdf5_output      = F , ! write output into hdf5 file
 fdebug           = 1 , ! flag for debugging messages
 fstatus          = 1 , ! flag for status messages
 ispecies         = 1 , ! number of ion species
/

&KIM_SETUP
 btor        = -17977.413 , ! toroidal magnetic field in Gauss
 R0          = 165.0 ,      ! major radius in cm
 m_mode      = 6 ,          ! poloidal mode number
 n_mode      = 2 ,          ! toroidal mode number
 Zi			 = 1,           ! ion charge number
 Ai			 = 2,           ! ion mass number
 k_space_dim = 20 ,        ! dimension of kr space
 l_space_dim = 100 ,        ! spline space dimension
 reduce_r    = .false. ,		! if true reduces r dim of input profiles
 reduced_r_dim = 100 ,      ! reduced radial dim of initial profiles
 omega       = 1e0 ,	    ! perturbation frequency
 spline_base = 1 ,          ! spline base functions: 1 - hat functions
 grid_spacing= 2 ,          ! grid spacing of new grid: 1 - equidistant, 2 - non-equidistant, more points at rational surface
 cut_off_fac = 5.0 ,        ! cut off factor for making the ll' kernel matrix sparse
 num_gengrid_points = 200   ! min number of points of the non equidistant grid
/
