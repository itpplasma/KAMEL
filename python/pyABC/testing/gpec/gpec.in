&gpec_input
    dcon_dir = './'
    idconfile = 'euler.bin'
    ieqfile = 'psi_in.bin'
    ivacuumfile = 'vacuum.bin'
    rdconfile = 'globalsol.bin'
    gal_flag = .false.
    jac_in = ''
    jsurf_in = 0
    tmag_in = 1
    mthsurf = 0
    coil_flag = .true.
    data_flag = .false.
    data_type = 'surfmn'
    infile = 'path/to/file'
    nmin = 0
    nmax = 64
    mmin = -64
    mmax = 64
    harmonic_flag = .false.
    cosmn(3) = 0.0001
    sinmn(6) = 0.0001
    displacement_flag = .false.
    fixed_boundary_flag = .false.
    mode_flag = .false.
    mode = 0
    filter_types = 'w'
    filter_modes = 0
/

&gpec_control
    resp_index = 0
    sing_spot = 0.0005
    sing_npsi = 100
    reg_flag = .true.
    reg_spot = 0.05
    chebyshev_flag = .false.
    nche = 20
    use_classic_splines = .false.
/

&gpec_output
    jac_out = ''
    jsurf_out = 1
    tmag_out = 1
    mlim_out = 64
    resp_flag = .true.
    filter_flag = .true.
    singcoup_flag = .true.
    singfld_flag = .true.
    vsingfld_flag = .true.
    pmodb_flag = .false.
    xbnormal_flag = .true.
    vbnormal_flag = .true.
    xclebsch_flag = .true.
    dw_flag = .true.
    eqbrzphi_flag = .true.
    brzphi_flag = .true.
    xrzphi_flag = .false.
    vbrzphi_flag = .false.
    vvbrzphi_flag = .false.
    vsbrzphi_flag = .false.
    ss_flag(3) = .false.
    xbrzphifun_flag = .false.
    arzphifun_flag = .false.
    nr = 128
    nz = 128
    fun_flag = .false.
    flux_flag = .false.
    netcdf_flag = .true.
    ascii_flag = .false.
    max_linesout = 0
    bin_flag = .false.
    bin_2d_flag = .false.
    verbose = .true.
/

&gpec_diagnose
    timeit = .false.
    radvar_flag = .false.
/
